# ============================================
# 智谱 AI API 配置
# 文档: https://docs.bigmodel.cn/cn/api/introduction
# ============================================

# --- 身份认证 ---
# 在 https://open.bigmodel.cn 获取
ZHIPU_API_KEY="your-api-key-here"

# --- 模型选择 ---
# 可选值: glm-4.7-flash | glm-4-flash-250414 | glm-4.5-air | glm-4.7 | glm-5.1
# 详见: https://docs.bigmodel.cn/cn/guide/start/model-overview
ZHIPU_MODEL="glm-4.7-flash"

# --- 生成参数 ---
ZHIPU_TEMPERATURE="0.1"
ZHIPU_MAX_TOKENS="512"

# --- 常规筛选规则（OR 门逻辑）---
FRONTIER_THRESHOLD="80"
SIGNAL_THRESHOLD="80"
COMPOSITE_THRESHOLD="60"
MAX_AGE_DAYS="5"

# --- ArXiv 筛选规则（OR 门逻辑）---
ARXIV_FRONTIER_THRESHOLD="70"
ARXIV_UTILITY_THRESHOLD="70"
ARXIV_COMPOSITE_THRESHOLD="65"
ARXIV_MAX_ITEMS_PER_SOURCE="100"
ARXIV_MAX_AFTER_COARSE="20"

# --- 爬取控制 ---
RSS_ITEMS_PER_SOURCE="5"
HTTP_TIMEOUT="15"

# --- 软监控 ---
MIN_ITEMS_PER_UPDATE="8"
